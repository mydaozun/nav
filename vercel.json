{
  "headers": [
    // 1. 所有常见静态资源（扩展名匹配，优先级最高）
    {
      "source": "/(.*)\\.(ico|png|jpg|jpeg|gif|svg|webp|avif|woff2?|ttf|eot)$",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    // 2. Astro 常见 hashed 资产文件夹（如果你的 CSS/JS 在 _astro/ 或 assets/）
    {
      "source": "/(_astro|assets)/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    // 3. 你的特定图像/图标文件夹（合并成一条，更高效）
    {
      "source": "/(images|icons|xw_assets)/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    // 4. CSS/JS（扩展名兜底）
    {
      "source": "/(.*)\\.(css|js)$",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    // 5. 可选兜底（Astro 静态页面默认 must-revalidate，可删）
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}